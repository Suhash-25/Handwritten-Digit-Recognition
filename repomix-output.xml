import tensorflow as tf
import gradio as gr
import numpy as np
import cv2
import os

# ELITE PATHING: Find out exactly where this app.py file lives
BASE_DIR = os.path.dirname(os.path.abspath(__file__))
# Build the absolute path to the model: go up one level (..), then into 'models'
MODEL_PATH = os.path.join(BASE_DIR, '..', 'models', 'digit_brain.h5')

# 1. Load the "Brain"
print(f"Loading model from: {MODEL_PATH}")
model = tf.keras.models.load_model(MODEL_PATH)

# 1. Load the "Brain" we trained in Phase 1
model = tf.keras.models.load_model('models/digit_brain.h5')

def predict_digit(data):
    # 1. Extract the image from Gradio
    img = data['composite'] 
    
    # 2. Convert to grayscale
    img = cv2.cvtColor(img, cv2.COLOR_RGBA2GRAY)
    
    # 3. ELITE FIX: Auto-Invert Colors
    # MNIST needs a BLACK background and WHITE ink.
    # We check the top-left pixel (index 0,0). If it's bright (white background), we invert the whole image.
    if img[0, 0] > 127: 
        img = cv2.bitwise_not(img) # Flips black to white and white to black
        
    # 4. ELITE FIX: Dilation (Make the lines thicker)
    # Neural networks struggle with razor-thin mouse lines. This "bolds" the ink.
    kernel = np.ones((3, 3), np.uint8)
    img = cv2.dilate(img, kernel, iterations=2)
    
    # 5. Resize to 28x28 and Normalize to 0-1
    img = cv2.resize(img, (28, 28))
    img = img / 255.0
    
    # 6. Reshape for the CNN (1 image, 28x28 pixels, 1 color channel)
    img = img.reshape(1, 28, 28, 1)

    # 7. Predict!
    prediction = model.predict(img)[0]
    
    return {str(i): float(prediction[i]) for i in range(10)}

# 4. DESIGN THE ELITE UI
label = gr.Label(num_top_classes=3) # Show the top 3 most likely digits

interface = gr.Interface(
    fn=predict_digit, 
    inputs=gr.Sketchpad(label="Draw a Digit (0-9)", type="numpy"), 
    outputs=label,
    live=True, # ELITE MODE: Predicts while you are still drawing!
    title="Elite Digit Recognition System",
    description="Draw a digit in the box and watch the AI think in real-time."
)

if __name__ == "__main__":
    interface.launch()
